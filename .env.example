# ─── Stepsy OAuth Configuration ───
# Create your Google Cloud project at https://console.cloud.google.com
# 1. Create project "Stepsy Sync"
# 2. Enable: Google Drive API
# 3. OAuth Consent Screen → External → Add scopes (drive.appdata, drive.file)
# 4. Credentials → Create OAuth 2.0 Client ID (Web application)
# 5. Add authorized origins: http://localhost:5173, http://localhost:5174, https://your-domain.com

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
